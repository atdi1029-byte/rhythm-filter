//@version=6
indicator("Rhythm Filter — Price Overlay",
     overlay=true, precision=2)

// === SETTINGS ===
grpRhy = "Rhythm"
rsiLen = input.int(14, "RSI Length", group=grpRhy)
buyZone = input.float(40, "Buy Zone (RSI <)",
     group=grpRhy)
sellZone = input.float(60, "Sell Zone (RSI >)",
     group=grpRhy)

grpVis = "Visual"
showBg = input.bool(true, "Phase Background",
     group=grpVis)
colorCandles = input.bool(true, "Color Candles",
     group=grpVis)
showLabels = input.bool(true, "Phase Flip Labels",
     group=grpVis)
showScore = input.bool(true, "Score Label (current)",
     group=grpVis)

// === PULL RSI FROM TOP 40 CRYPTOS ===
tf = timeframe.period

btcRsi  = request.security("BINANCE:BTCUSDT",  tf,
     ta.rsi(close, rsiLen))
ethRsi  = request.security("BINANCE:ETHUSDT",  tf,
     ta.rsi(close, rsiLen))
xrpRsi  = request.security("BINANCE:XRPUSDT",  tf,
     ta.rsi(close, rsiLen))
bnbRsi  = request.security("BINANCE:BNBUSDT",  tf,
     ta.rsi(close, rsiLen))
solRsi  = request.security("BINANCE:SOLUSDT",  tf,
     ta.rsi(close, rsiLen))
dogeRsi = request.security("BINANCE:DOGEUSDT", tf,
     ta.rsi(close, rsiLen))
adaRsi  = request.security("BINANCE:ADAUSDT",  tf,
     ta.rsi(close, rsiLen))
trxRsi  = request.security("BINANCE:TRXUSDT",  tf,
     ta.rsi(close, rsiLen))
avaxRsi = request.security("BINANCE:AVAXUSDT", tf,
     ta.rsi(close, rsiLen))
shibRsi = request.security("BINANCE:SHIBUSDT", tf,
     ta.rsi(close, rsiLen))
tonRsi  = request.security("BINANCE:TONUSDT",  tf,
     ta.rsi(close, rsiLen))
linkRsi = request.security("BINANCE:LINKUSDT", tf,
     ta.rsi(close, rsiLen))
suiRsi  = request.security("BINANCE:SUIUSDT",  tf,
     ta.rsi(close, rsiLen))
dotRsi  = request.security("BINANCE:DOTUSDT",  tf,
     ta.rsi(close, rsiLen))
nearRsi = request.security("BINANCE:NEARUSDT", tf,
     ta.rsi(close, rsiLen))
uniRsi  = request.security("BINANCE:UNIUSDT",  tf,
     ta.rsi(close, rsiLen))
aptRsi  = request.security("BINANCE:APTUSDT",  tf,
     ta.rsi(close, rsiLen))
polRsi  = request.security("BINANCE:POLUSDT",  tf,
     ta.rsi(close, rsiLen))
arbRsi  = request.security("BINANCE:ARBUSDT",  tf,
     ta.rsi(close, rsiLen))
opRsi   = request.security("BINANCE:OPUSDT",   tf,
     ta.rsi(close, rsiLen))

icpRsi   = request.security("BINANCE:ICPUSDT",   tf,
     ta.rsi(close, rsiLen))
hbarRsi  = request.security("BINANCE:HBARUSDT",  tf,
     ta.rsi(close, rsiLen))
filRsi   = request.security("BINANCE:FILUSDT",   tf,
     ta.rsi(close, rsiLen))
atomRsi  = request.security("BINANCE:ATOMUSDT",  tf,
     ta.rsi(close, rsiLen))
imxRsi   = request.security("BINANCE:IMXUSDT",   tf,
     ta.rsi(close, rsiLen))
injRsi   = request.security("BINANCE:INJUSDT",   tf,
     ta.rsi(close, rsiLen))
stxRsi   = request.security("BINANCE:STXUSDT",   tf,
     ta.rsi(close, rsiLen))
ftmRsi   = request.security("BINANCE:SUSDT",     tf,
     ta.rsi(close, rsiLen))
grtRsi   = request.security("BINANCE:GRTUSDT",   tf,
     ta.rsi(close, rsiLen))
thetaRsi = request.security("BINANCE:THETAUSDT", tf,
     ta.rsi(close, rsiLen))
algoRsi  = request.security("BINANCE:ALGOUSDT",  tf,
     ta.rsi(close, rsiLen))
ldoRsi   = request.security("BINANCE:LDOUSDT",   tf,
     ta.rsi(close, rsiLen))
aaveRsi  = request.security("BINANCE:AAVEUSDT",  tf,
     ta.rsi(close, rsiLen))
mkrRsi   = request.security("BINANCE:SKYUSDT",   tf,
     ta.rsi(close, rsiLen))
snxRsi   = request.security("BINANCE:SNXUSDT",   tf,
     ta.rsi(close, rsiLen))

vetRsi   = request.security("BINANCE:VETUSDT",   tf,
     ta.rsi(close, rsiLen))
xlmRsi   = request.security("BINANCE:XLMUSDT",   tf,
     ta.rsi(close, rsiLen))
pepeRsi  = request.security("BINANCE:PEPEUSDT",  tf,
     ta.rsi(close, rsiLen))
fetRsi   = request.security("BINANCE:FETUSDT",   tf,
     ta.rsi(close, rsiLen))
eosRsi   = request.security("BINANCE:WLDUSDT",   tf,
     ta.rsi(close, rsiLen))

// === SCORE EACH COIN ===
TOTAL_COINS = 40

scoreIt(float rsi) =>
    rsi < buyZone ? 1 :
     rsi > sellZone ? -1 : 0

rawScore = scoreIt(btcRsi) + scoreIt(ethRsi) +
     scoreIt(xrpRsi) + scoreIt(bnbRsi) +
     scoreIt(solRsi) + scoreIt(dogeRsi) +
     scoreIt(adaRsi) + scoreIt(trxRsi) +
     scoreIt(avaxRsi) + scoreIt(shibRsi) +
     scoreIt(tonRsi) + scoreIt(linkRsi) +
     scoreIt(suiRsi) + scoreIt(dotRsi) +
     scoreIt(nearRsi) + scoreIt(uniRsi) +
     scoreIt(aptRsi) + scoreIt(polRsi) +
     scoreIt(arbRsi) + scoreIt(opRsi) +
     scoreIt(icpRsi) + scoreIt(hbarRsi) +
     scoreIt(filRsi) + scoreIt(atomRsi) +
     scoreIt(imxRsi) + scoreIt(injRsi) +
     scoreIt(stxRsi) + scoreIt(ftmRsi) +
     scoreIt(grtRsi) + scoreIt(thetaRsi) +
     scoreIt(algoRsi) + scoreIt(ldoRsi) +
     scoreIt(aaveRsi) + scoreIt(mkrRsi) +
     scoreIt(snxRsi) + scoreIt(vetRsi) +
     scoreIt(xlmRsi) + scoreIt(pepeRsi) +
     scoreIt(fetRsi) + scoreIt(eosRsi)

normalizedScore = rawScore * 20.0 / TOTAL_COINS
breathScore = ta.ema(normalizedScore, 9)

// === PHASE ===
isBuyPhase  = breathScore >= 5
isSellPhase = breathScore <= -5
isNeutral   = not isBuyPhase and not isSellPhase

// === INTENSITY (0-1 scale for color mixing) ===
// Score range is roughly -20 to +20
// Map absolute score to 0-1 for transparency
intensity = math.min(math.abs(breathScore) / 15.0, 1.0)

// === BACKGROUND COLORING ===
// Stronger phase = less transparent
bgAlpha = isBuyPhase ?
     math.round(95 - intensity * 15) :
     isSellPhase ?
     math.round(95 - intensity * 15) : 100

bgcolor(showBg and isBuyPhase ?
     color.new(#00E676, bgAlpha) :
     showBg and isSellPhase ?
     color.new(#FF1744, bgAlpha) : na,
     title="Phase Background")

// === CANDLE COLORING ===
// Deep score = vivid, fading score = pale
candleUp = breathScore > 10 ?
     color.new(#00E676, 0) :
     breathScore > 5 ?
     color.new(#00E676, 20) :
     breathScore > 0 ?
     color.new(#81C784, 30) :
     breathScore > -5 ?
     color.new(#EF9A9A, 30) :
     breathScore > -10 ?
     color.new(#FF1744, 20) :
     color.new(#FF1744, 0)

candleDown = breathScore > 10 ?
     color.new(#00C853, 0) :
     breathScore > 5 ?
     color.new(#00C853, 20) :
     breathScore > 0 ?
     color.new(#66BB6A, 30) :
     breathScore > -5 ?
     color.new(#E57373, 30) :
     breathScore > -10 ?
     color.new(#D32F2F, 20) :
     color.new(#D32F2F, 0)

barcolor(colorCandles ? (close >= open ?
     candleUp : candleDown) : na,
     title="Rhythm Candle Color")

// === PHASE FLIP LABELS ===
inhaleFlip = isBuyPhase and not isBuyPhase[1]
exhaleFlip = isSellPhase and not isSellPhase[1]

plotshape(showLabels and inhaleFlip,
     title="INHALE",
     location=location.belowbar,
     style=shape.labelup,
     size=size.small,
     color=color.new(#00E676, 20),
     text="INHALE",
     textcolor=color.white)

plotshape(showLabels and exhaleFlip,
     title="EXHALE",
     location=location.abovebar,
     style=shape.labeldown,
     size=size.small,
     color=color.new(#FF1744, 20),
     text="EXHALE",
     textcolor=color.white)

// === CURRENT SCORE LABEL ===
if barstate.islast and showScore
    scoreStr = str.tostring(breathScore, "#.#")
    phase = isBuyPhase ? "INHALE" :
         isSellPhase ? "EXHALE" : "BETWEEN"
    lblCol = isBuyPhase ?
         color.new(#00E676, 20) :
         isSellPhase ?
         color.new(#FF1744, 20) :
         color.new(#FFD600, 20)
    label.new(bar_index + 2, close,
         phase + " " + scoreStr,
         color=lblCol,
         textcolor=color.white,
         style=label.style_label_left,
         size=size.normal)

// === EXPORT SCORE FOR OTHER INDICATORS ===
plot(breathScore, "Breathing Score",
     display=display.data_window)
