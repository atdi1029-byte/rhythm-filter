//@version=6
indicator("Rhythm Short — SL/TP Overlay", overlay=true,
     max_lines_count=500, max_labels_count=500)

// Stacked trades: every SHORT is independent, no cancelling

// === SETTINGS ===
grpRhy = "Rhythm"
rsiLen = input.int(14, "RSI Length", group=grpRhy)
buyZone = input.float(40, "Buy Zone (RSI <)", group=grpRhy)
sellZone = input.float(60, "Sell Zone (RSI >)", group=grpRhy)

grpShort = "Short Signal"
shortThreshold = input.float(-5.0, "Deep Red Threshold",
     group=grpShort, step=1.0)
shortCooldown = input.int(12, "Cooldown (bars)",
     group=grpShort, minval=1)
slPct = input.float(5.0, "Stop Loss %",
     group=grpShort, step=0.5, minval=0.5)
tpPct = input.float(5.0, "Take Profit %",
     group=grpShort, step=0.5, minval=0.5)

grpDate = "Date Filter"
useDateFilter = input.bool(true, "Use Date Filter",
     group=grpDate)
startDate = input.time(timestamp("2026-03-01"),
     "Start Date", group=grpDate)
endDate = input.time(timestamp("2030-01-01"),
     "End Date", group=grpDate)

grpTrade = "Trade Size"
positionSize = input.float(100.0, "Position Size ($)",
     group=grpTrade, step=10)
leverage = input.float(20.0, "Leverage",
     group=grpTrade, step=1, minval=1)

// Date filter check
inDateRange = not useDateFilter or
     (time >= startDate and time <= endDate)

// === PULL RSI FROM TOP 40 CRYPTOS ===
tf = timeframe.period

btcRsi  = request.security("BINANCE:BTCUSDT",  tf, ta.rsi(close, rsiLen))
ethRsi  = request.security("BINANCE:ETHUSDT",  tf, ta.rsi(close, rsiLen))
xrpRsi  = request.security("BINANCE:XRPUSDT",  tf, ta.rsi(close, rsiLen))
bnbRsi  = request.security("BINANCE:BNBUSDT",  tf, ta.rsi(close, rsiLen))
solRsi  = request.security("BINANCE:SOLUSDT",  tf, ta.rsi(close, rsiLen))
dogeRsi = request.security("BINANCE:DOGEUSDT", tf, ta.rsi(close, rsiLen))
adaRsi  = request.security("BINANCE:ADAUSDT",  tf, ta.rsi(close, rsiLen))
trxRsi  = request.security("BINANCE:TRXUSDT",  tf, ta.rsi(close, rsiLen))
avaxRsi = request.security("BINANCE:AVAXUSDT", tf, ta.rsi(close, rsiLen))
shibRsi = request.security("BINANCE:SHIBUSDT", tf, ta.rsi(close, rsiLen))
tonRsi  = request.security("BINANCE:TONUSDT",  tf, ta.rsi(close, rsiLen))
linkRsi = request.security("BINANCE:LINKUSDT", tf, ta.rsi(close, rsiLen))
suiRsi  = request.security("BINANCE:SUIUSDT",  tf, ta.rsi(close, rsiLen))
dotRsi  = request.security("BINANCE:DOTUSDT",  tf, ta.rsi(close, rsiLen))
nearRsi = request.security("BINANCE:NEARUSDT", tf, ta.rsi(close, rsiLen))
uniRsi  = request.security("BINANCE:UNIUSDT",  tf, ta.rsi(close, rsiLen))
aptRsi  = request.security("BINANCE:APTUSDT",  tf, ta.rsi(close, rsiLen))
polRsi  = request.security("BINANCE:POLUSDT",  tf, ta.rsi(close, rsiLen))
arbRsi  = request.security("BINANCE:ARBUSDT",  tf, ta.rsi(close, rsiLen))
opRsi   = request.security("BINANCE:OPUSDT",   tf, ta.rsi(close, rsiLen))
icpRsi   = request.security("BINANCE:ICPUSDT",   tf, ta.rsi(close, rsiLen))
hbarRsi  = request.security("BINANCE:HBARUSDT",  tf, ta.rsi(close, rsiLen))
filRsi   = request.security("BINANCE:FILUSDT",   tf, ta.rsi(close, rsiLen))
atomRsi  = request.security("BINANCE:ATOMUSDT",  tf, ta.rsi(close, rsiLen))
imxRsi   = request.security("BINANCE:IMXUSDT",   tf, ta.rsi(close, rsiLen))
injRsi   = request.security("BINANCE:INJUSDT",   tf, ta.rsi(close, rsiLen))
stxRsi   = request.security("BINANCE:STXUSDT",   tf, ta.rsi(close, rsiLen))
ftmRsi   = request.security("BINANCE:SUSDT",     tf, ta.rsi(close, rsiLen))
grtRsi   = request.security("BINANCE:GRTUSDT",   tf, ta.rsi(close, rsiLen))
thetaRsi = request.security("BINANCE:THETAUSDT", tf, ta.rsi(close, rsiLen))
algoRsi  = request.security("BINANCE:ALGOUSDT",  tf, ta.rsi(close, rsiLen))
ldoRsi   = request.security("BINANCE:LDOUSDT",   tf, ta.rsi(close, rsiLen))
aaveRsi  = request.security("BINANCE:AAVEUSDT",  tf, ta.rsi(close, rsiLen))
mkrRsi   = request.security("BINANCE:SKYUSDT",   tf, ta.rsi(close, rsiLen))
snxRsi   = request.security("BINANCE:SNXUSDT",   tf, ta.rsi(close, rsiLen))
vetRsi   = request.security("BINANCE:VETUSDT",   tf, ta.rsi(close, rsiLen))
xlmRsi   = request.security("BINANCE:XLMUSDT",   tf, ta.rsi(close, rsiLen))
pepeRsi  = request.security("BINANCE:PEPEUSDT",  tf, ta.rsi(close, rsiLen))
fetRsi   = request.security("BINANCE:FETUSDT",   tf, ta.rsi(close, rsiLen))
eosRsi   = request.security("BINANCE:WLDUSDT",   tf, ta.rsi(close, rsiLen))

// === SCORE ===
TOTAL_COINS = 40
scoreIt(float rsi) =>
    rsi < buyZone ? 1 : rsi > sellZone ? -1 : 0

rawScore = scoreIt(btcRsi) + scoreIt(ethRsi) + scoreIt(xrpRsi) +
     scoreIt(bnbRsi) + scoreIt(solRsi) + scoreIt(dogeRsi) +
     scoreIt(adaRsi) + scoreIt(trxRsi) + scoreIt(avaxRsi) +
     scoreIt(shibRsi) + scoreIt(tonRsi) + scoreIt(linkRsi) +
     scoreIt(suiRsi) + scoreIt(dotRsi) + scoreIt(nearRsi) +
     scoreIt(uniRsi) + scoreIt(aptRsi) + scoreIt(polRsi) +
     scoreIt(arbRsi) + scoreIt(opRsi) +
     scoreIt(icpRsi) + scoreIt(hbarRsi) + scoreIt(filRsi) +
     scoreIt(atomRsi) + scoreIt(imxRsi) + scoreIt(injRsi) +
     scoreIt(stxRsi) + scoreIt(ftmRsi) + scoreIt(grtRsi) +
     scoreIt(thetaRsi) + scoreIt(algoRsi) + scoreIt(ldoRsi) +
     scoreIt(aaveRsi) + scoreIt(mkrRsi) + scoreIt(snxRsi) +
     scoreIt(vetRsi) + scoreIt(xlmRsi) + scoreIt(pepeRsi) +
     scoreIt(fetRsi) + scoreIt(eosRsi)

breathScore = ta.ema(rawScore * 20.0 / TOTAL_COINS, 9)

// === SHORT SIGNAL DETECTION ===
var bool wasGreen = false
var float recentPeak = 0.0
var bool shortArmed = false
var float troughVal = 0.0
var int lastShortBar = 0

if breathScore > 0
    wasGreen := true
    if breathScore > recentPeak
        recentPeak := breathScore

if breathScore < shortThreshold and wasGreen
    shortArmed := true
    if breathScore < troughVal
        troughVal := breathScore

shortFired = false
if shortArmed and breathScore > breathScore[1]
     and breathScore[1] <= breathScore[2]
     and breathScore < 0
     and (bar_index - lastShortBar) >= shortCooldown
     and inDateRange
    shortFired := true
    shortArmed := false
    lastShortBar := bar_index
    troughVal := 0.0
    wasGreen := false
    recentPeak := 0.0

if shortArmed and breathScore > 0
    shortArmed := false
    troughVal := 0.0
    wasGreen := false
    recentPeak := 0.0

// === STACKED TRADE TRACKING (arrays) ===
// Each SHORT opens its own independent trade
var array<float> tradeEntry = array.new_float()
var array<float> tradeSL = array.new_float()
var array<float> tradeTP = array.new_float()
var array<line> tradeEntryLines = array.new_line()
var array<line> tradeSLLines = array.new_line()
var array<line> tradeTPLines = array.new_line()

// Running totals
var float totalPnL = 0.0
var int totalWins = 0
var int totalLosses = 0

dollarGain = positionSize * leverage * tpPct / 100
dollarLoss = positionSize * leverage * slPct / 100

// New SHORT signal — open a NEW independent trade
if shortFired
    array.push(tradeEntry, close)
    array.push(tradeSL, close * (1 + slPct / 100))
    array.push(tradeTP, close * (1 - tpPct / 100))

    // Orange entry line
    array.push(tradeEntryLines, line.new(
         bar_index, close, bar_index + 1, close,
         color=color.new(#FF6D00, 0),
         width=2, style=line.style_solid,
         extend=extend.right))

    // Red SL line
    array.push(tradeSLLines, line.new(
         bar_index, close * (1 + slPct / 100),
         bar_index + 1, close * (1 + slPct / 100),
         color=color.new(#FF1744, 0), width=2,
         style=line.style_dashed,
         extend=extend.right))

    // Green TP line
    array.push(tradeTPLines, line.new(
         bar_index, close * (1 - tpPct / 100),
         bar_index + 1, close * (1 - tpPct / 100),
         color=color.new(#00E676, 0), width=2,
         style=line.style_dashed,
         extend=extend.right))

// Check ALL active trades for SL/TP hits
// Walk backwards so we can safely remove by index
if array.size(tradeEntry) > 0
    for i = array.size(tradeEntry) - 1 to 0
        ePrice = array.get(tradeEntry, i)
        slP = array.get(tradeSL, i)
        tpP = array.get(tradeTP, i)
        eLine = array.get(tradeEntryLines, i)
        sLine = array.get(tradeSLLines, i)
        tLine = array.get(tradeTPLines, i)

        if high >= slP
            // STOPPED OUT
            line.set_extend(eLine, extend.none)
            line.set_extend(sLine, extend.none)
            line.set_extend(tLine, extend.none)
            line.set_x2(eLine, bar_index)
            line.set_x2(sLine, bar_index)
            line.set_x2(tLine, bar_index)
            totalPnL -= dollarLoss
            totalLosses += 1
            label.new(bar_index, slP,
                 "L -$" + str.tostring(dollarLoss, "#.##"),
                 color=color.new(#FF1744, 0),
                 textcolor=color.white,
                 style=label.style_label_down,
                 size=size.normal)
            // Remove from arrays
            array.remove(tradeEntry, i)
            array.remove(tradeSL, i)
            array.remove(tradeTP, i)
            array.remove(tradeEntryLines, i)
            array.remove(tradeSLLines, i)
            array.remove(tradeTPLines, i)

        else if low <= tpP
            // TP HIT
            line.set_extend(eLine, extend.none)
            line.set_extend(sLine, extend.none)
            line.set_extend(tLine, extend.none)
            line.set_x2(eLine, bar_index)
            line.set_x2(sLine, bar_index)
            line.set_x2(tLine, bar_index)
            totalPnL += dollarGain
            totalWins += 1
            label.new(bar_index, tpP,
                 "W +$" + str.tostring(dollarGain, "#.##"),
                 color=color.new(#00E676, 0),
                 textcolor=color.white,
                 style=label.style_label_up,
                 size=size.normal)
            // Remove from arrays
            array.remove(tradeEntry, i)
            array.remove(tradeSL, i)
            array.remove(tradeTP, i)
            array.remove(tradeEntryLines, i)
            array.remove(tradeSLLines, i)
            array.remove(tradeTPLines, i)

// SHORT arrow
plotshape(shortFired, title="SHORT",
     location=location.abovebar,
     style=shape.triangledown,
     size=size.small,
     color=color.new(#FF6D00, 0),
     text="SHORT")

// === SCOREBOARD ===
var table scoreBoard = table.new(position.top_right,
     2, 7, bgcolor=color.new(#000000, 20),
     border_color=color.new(#444444, 0), border_width=1)

if barstate.islast
    // SL / TP row
    table.cell(scoreBoard, 0, 0, "SL / TP",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 0,
         str.tostring(slPct, "#.#") + "% / " +
         str.tostring(tpPct, "#.#") + "%",
         text_color=color.new(#FF6D00, 0), text_size=size.small)

    // Total P&L
    table.cell(scoreBoard, 0, 1, "Total P&L",
         text_color=color.white, text_size=size.normal)
    pnlColor = totalPnL >= 0 ? color.green : color.red
    pnlSign = totalPnL >= 0 ? "+$" : "-$"
    table.cell(scoreBoard, 1, 1,
         pnlSign + str.tostring(math.abs(totalPnL), "#.##"),
         text_color=pnlColor, text_size=size.normal)

    // Wins
    table.cell(scoreBoard, 0, 2, "Wins",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 2,
         str.tostring(totalWins),
         text_color=color.new(#00E676, 0), text_size=size.small)

    // Losses
    table.cell(scoreBoard, 0, 3, "Losses",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 3,
         str.tostring(totalLosses),
         text_color=color.new(#FF1744, 0), text_size=size.small)

    // Win Rate
    wr = totalWins + totalLosses > 0 ?
         totalWins * 100.0 / (totalWins + totalLosses) : 0.0
    table.cell(scoreBoard, 0, 4, "Win Rate",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 4,
         str.tostring(wr, "#.#") + "%",
         text_color=color.white, text_size=size.small)

    // Trades count
    table.cell(scoreBoard, 0, 5, "Trades",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 5,
         str.tostring(totalWins + totalLosses),
         text_color=color.white, text_size=size.small)

    // Open trades
    table.cell(scoreBoard, 0, 6, "Open",
         text_color=color.gray, text_size=size.small)
    table.cell(scoreBoard, 1, 6,
         str.tostring(array.size(tradeEntry)),
         text_color=color.new(#FF6D00, 0), text_size=size.small)
