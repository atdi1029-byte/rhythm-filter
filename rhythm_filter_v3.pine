//@version=6
indicator("Rhythm Filter v3", overlay=false, precision=2)

// Rhythm Filter v3 — The Heartbeat
// A continuous wave that NEVER resets
// Anchors to the first signal, then oscillates forever
// Green = buy window, Red = sell window
// Your signals land on the wave — green = take, red = skip

// === SIGNAL SOURCES ===
grpSrc = "Signal Sources"
buySrc = input.source(close, "Buy Signal Source",
     group=grpSrc,
     tooltip="Select 'Signal Out' from v8")
sellSrc = input.source(close, "Sell Signal Source",
     group=grpSrc,
     tooltip="Select 'Signal Out' from v3")

// === RHYTHM TIMING ===
grpRhy = "Rhythm Timing"
buyToSell = input.float(17, "Buy → Sell (days)",
     group=grpRhy)
sellToBuy = input.float(10, "Sell → Buy (days)",
     group=grpRhy)

// === DETECT SIGNALS ===
buyFired  = buySrc > 0.5 and buySrc[1] < 0.5
sellFired = sellSrc > 0.5 and sellSrc[1] < 0.5

var int buyCount = 0
var int sellCount = 0
if buyFired
    buyCount += 1
if sellFired
    sellCount += 1

// === ANCHOR — set ONCE, never reset ===
var float anchorTime = na
var int anchorType = 0

if na(anchorTime)
    if buyFired
        anchorTime := time
        anchorType := 1
    else if sellFired
        anchorTime := time
        anchorType := -1

// === THE WAVE — never stops ===
fullCycle = buyToSell + sellToBuy

wave = float(na)

if not na(anchorTime)
    daysSinceAnchor = (time - anchorTime) / (1000.0 * 86400.0)

    // Offset so the wave starts at the right phase
    float offset = 0.0
    if anchorType == -1
        offset := buyToSell

    cycleDay = (daysSinceAnchor + offset) % fullCycle

    // First half: buy peak (+1) drifting to sell trough (-1)
    // Second half: sell trough (-1) drifting to buy peak (+1)
    if cycleDay < buyToSell
        wave := 1.0 - 2.0 * cycleDay / buyToSell
    else
        elapsed = cycleDay - buyToSell
        wave := -1.0 + 2.0 * elapsed / sellToBuy


// === DISPLAY ===

// Wave color
waveColor = not na(wave) and wave > 0.3 ?
     color.new(#4CAF50, 0) :
     not na(wave) and wave < -0.3 ?
     color.new(#FF1744, 0) :
     color.new(#FFD600, 0)

wavePlot = plot(wave, "Rhythm Wave",
     color=waveColor, linewidth=3)

// Fill
zeroPlot = plot(0.0, "Zero",
     color=color.new(#666666, 90))
fill(wavePlot, zeroPlot,
     color=not na(wave) and wave > 0 ?
         color.new(#4CAF50, 80) :
         color.new(#FF1744, 80),
     title="Wave Fill")

// Lines
hline(1.0, "Buy Peak",
     color=color.new(#4CAF50, 50),
     linestyle=hline.style_dotted)
hline(-1.0, "Sell Peak",
     color=color.new(#FF1744, 50),
     linestyle=hline.style_dotted)
hline(0.0, "Neutral",
     color=color.new(#666666, 50),
     linestyle=hline.style_dotted)

// Background: green when wave > 0, red when < 0
bgcolor(not na(wave) and wave > 0.5 ?
     color.new(#4CAF50, 90) :
     not na(wave) and wave < -0.5 ?
     color.new(#FF1744, 90) : na,
     title="Phase BG")

// Signal markers
plotshape(buyFired, "BUY", shape.triangleup,
     location.bottom, color=color.new(#00E676, 0),
     size=size.small)
plotshape(sellFired, "SELL", shape.triangledown,
     location.top, color=color.new(#FF1744, 0),
     size=size.small)

// Buy labels — does the signal align with the wave?
if buyFired
    advice = not na(wave) and wave > 0.3 ? "ALIGNED" :
         not na(wave) and wave < -0.3 ? "AGAINST" :
         "NEUTRAL"
    advColor = not na(wave) and wave > 0.3 ?
         color.new(#00E676, 10) :
         not na(wave) and wave < -0.3 ?
         color.new(#FF1744, 10) :
         color.new(#FFD600, 10)
    label.new(bar_index, wave,
         "BUY\n" + advice,
         style=label.style_label_up,
         color=advColor,
         textcolor=color.white,
         size=size.tiny)

if sellFired
    advice = not na(wave) and wave < -0.3 ? "ALIGNED" :
         not na(wave) and wave > 0.3 ? "AGAINST" :
         "NEUTRAL"
    advColor = not na(wave) and wave < -0.3 ?
         color.new(#FF1744, 10) :
         not na(wave) and wave > 0.3 ?
         color.new(#00E676, 10) :
         color.new(#FFD600, 10)
    label.new(bar_index, wave,
         "SELL\n" + advice,
         style=label.style_label_down,
         color=advColor,
         textcolor=color.white,
         size=size.tiny)


// === INFO TABLE ===
var table t = table.new(position.top_right, 2, 5,
     bgcolor=color.new(#1E1E1E, 10),
     border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "Rhythm Filter",
         text_color=color.white, text_size=size.small,
         bgcolor=color.new(#333333, 0))
    zone = not na(wave) and wave > 0.5 ? "BUY WINDOW" :
         not na(wave) and wave < -0.5 ? "SELL WINDOW" :
         not na(wave) and wave > 0 ? "→ SELL" :
         not na(wave) and wave <= 0 ? "→ BUY" : "—"
    zCol = not na(wave) and wave > 0.5 ? color.green :
         not na(wave) and wave < -0.5 ? color.red :
         color.yellow
    table.cell(t, 1, 0, zone,
         text_color=zCol, text_size=size.small,
         bgcolor=color.new(#333333, 0))

    table.cell(t, 0, 1, "Wave",
         text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1,
         not na(wave) ?
         str.tostring(wave, "#.##") : "—",
         text_color=zCol, text_size=size.tiny)

    // Next phase prediction
    if not na(anchorTime)
        daysSinceAnchor = (time - anchorTime) /
             (1000.0 * 86400.0)
        float offset = anchorType == -1 ? buyToSell : 0.0
        cycleDay = (daysSinceAnchor + offset) % fullCycle

        nextLabel = ""
        nextDays = float(na)
        if cycleDay < buyToSell
            nextLabel := "Sell in"
            nextDays := buyToSell - cycleDay
        else
            nextLabel := "Buy in"
            nextDays := fullCycle - cycleDay

        table.cell(t, 0, 2, "Next",
             text_color=color.gray, text_size=size.tiny)
        table.cell(t, 1, 2,
             nextLabel + " " +
             str.tostring(nextDays, "#") + "d",
             text_color=color.white,
             text_size=size.tiny)

    table.cell(t, 0, 3, "Longs",
         text_color=color.gray, text_size=size.tiny)
    longAdv = not na(wave) and wave > 0.3 ? "GO" :
         not na(wave) and wave < -0.3 ? "NO" :
         "WAIT"
    longCol = not na(wave) and wave > 0.3 ? color.green :
         not na(wave) and wave < -0.3 ? color.red :
         color.yellow
    table.cell(t, 1, 3, longAdv,
         text_color=longCol, text_size=size.tiny)

    table.cell(t, 0, 4, "Events",
         text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4,
         str.tostring(buyCount) + "B / " +
         str.tostring(sellCount) + "S",
         text_color=color.white, text_size=size.tiny)
