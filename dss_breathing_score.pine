//@version=6
indicator("DSS Breathing Score — 40 Coin Composite",
     overlay=false, precision=1)

// === SETTINGS ===
grpDSS = "DSS Bressert"
dssStochLen = input.int(13, "Stochastic Period",
     group=grpDSS, minval=2)
dssEmaLen = input.int(8, "EMA Smoothing",
     group=grpDSS, minval=2)
obLevel = input.float(77, "Overbought (Sell Zone)",
     group=grpDSS, minval=50, maxval=100)
osLevel = input.float(23, "Oversold (Buy Zone)",
     group=grpDSS, minval=0, maxval=50)

grpScore = "Composite Score"
scoreTf = input.timeframe("D", "Timeframe",
     group=grpScore,
     tooltip="Timeframe to compute DSS on each coin")
scoreEmaLen = input.int(9, "Score EMA Length",
     group=grpScore, minval=1)

grpShort = "Short Signal"
shortThreshold = input.float(-3.0, "Deep Red Threshold",
     group=grpShort, step=1.0,
     tooltip="Score must drop below this to arm")
shortCooldown = input.int(12, "Cooldown (bars)",
     group=grpShort, minval=1)

// === DSS BRESSERT FUNCTION ===
dss_bressert(float src, int stochLen,
     int emaLen) =>
    hh = ta.highest(src, stochLen)
    ll = ta.lowest(src, stochLen)
    raw1 = hh != ll ?
         (src - ll) / (hh - ll) * 100 : 50.0
    smooth1 = ta.ema(raw1, emaLen)
    hh2 = ta.highest(smooth1, stochLen)
    ll2 = ta.lowest(smooth1, stochLen)
    raw2 = hh2 != ll2 ?
         (smooth1 - ll2) / (hh2 - ll2) * 100 : 50.0
    ta.ema(raw2, emaLen)

// === PULL DSS FROM TOP 40 CRYPTOS ===
// Original 20
btcDss  = request.security("BINANCE:BTCUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
ethDss  = request.security("BINANCE:ETHUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
xrpDss  = request.security("BINANCE:XRPUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
bnbDss  = request.security("BINANCE:BNBUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
solDss  = request.security("BINANCE:SOLUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
dogeDss = request.security("BINANCE:DOGEUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
adaDss  = request.security("BINANCE:ADAUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
trxDss  = request.security("BINANCE:TRXUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
avaxDss = request.security("BINANCE:AVAXUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
shibDss = request.security("BINANCE:SHIBUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
tonDss  = request.security("BINANCE:TONUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
linkDss = request.security("BINANCE:LINKUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
suiDss  = request.security("BINANCE:SUIUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
dotDss  = request.security("BINANCE:DOTUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
nearDss = request.security("BINANCE:NEARUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
uniDss  = request.security("BINANCE:UNIUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
aptDss  = request.security("BINANCE:APTUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
polDss  = request.security("BINANCE:POLUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
arbDss  = request.security("BINANCE:ARBUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
opDss   = request.security("BINANCE:OPUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))

// New 15
icpDss   = request.security("BINANCE:ICPUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
hbarDss  = request.security("BINANCE:HBARUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
filDss   = request.security("BINANCE:FILUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
atomDss  = request.security("BINANCE:ATOMUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
imxDss   = request.security("BINANCE:IMXUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
injDss   = request.security("BINANCE:INJUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
stxDss   = request.security("BINANCE:STXUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
ftmDss   = request.security("BINANCE:SUSDT",     scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
grtDss   = request.security("BINANCE:GRTUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
thetaDss = request.security("BINANCE:THETAUSDT", scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
algoDss  = request.security("BINANCE:ALGOUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
ldoDss   = request.security("BINANCE:LDOUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
aaveDss  = request.security("BINANCE:AAVEUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
mkrDss   = request.security("BINANCE:SKYUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
snxDss   = request.security("BINANCE:SNXUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))

// Final 5
vetDss   = request.security("BINANCE:VETUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
xlmDss   = request.security("BINANCE:XLMUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
pepeDss  = request.security("BINANCE:PEPEUSDT",  scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
fetDss   = request.security("BINANCE:FETUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))
wldDss   = request.security("BINANCE:WLDUSDT",   scoreTf,
     dss_bressert(close, dssStochLen, dssEmaLen))

// === SCORE EACH COIN ===
TOTAL_COINS = 40

scoreIt(float dss) =>
    dss < osLevel ? 1 :
     dss > obLevel ? -1 : 0

btcScore  = scoreIt(btcDss)
ethScore  = scoreIt(ethDss)
xrpScore  = scoreIt(xrpDss)
bnbScore  = scoreIt(bnbDss)
solScore  = scoreIt(solDss)
dogeScore = scoreIt(dogeDss)
adaScore  = scoreIt(adaDss)
trxScore  = scoreIt(trxDss)
avaxScore = scoreIt(avaxDss)
shibScore = scoreIt(shibDss)
tonScore  = scoreIt(tonDss)
linkScore = scoreIt(linkDss)
suiScore  = scoreIt(suiDss)
dotScore  = scoreIt(dotDss)
nearScore = scoreIt(nearDss)
uniScore  = scoreIt(uniDss)
aptScore  = scoreIt(aptDss)
polScore  = scoreIt(polDss)
arbScore  = scoreIt(arbDss)
opScore   = scoreIt(opDss)
icpScore   = scoreIt(icpDss)
hbarScore  = scoreIt(hbarDss)
filScore   = scoreIt(filDss)
atomScore  = scoreIt(atomDss)
imxScore   = scoreIt(imxDss)
injScore   = scoreIt(injDss)
stxScore   = scoreIt(stxDss)
ftmScore   = scoreIt(ftmDss)
grtScore   = scoreIt(grtDss)
thetaScore = scoreIt(thetaDss)
algoScore  = scoreIt(algoDss)
ldoScore   = scoreIt(ldoDss)
aaveScore  = scoreIt(aaveDss)
mkrScore   = scoreIt(mkrDss)
snxScore   = scoreIt(snxDss)
vetScore   = scoreIt(vetDss)
xlmScore   = scoreIt(xlmDss)
pepeScore  = scoreIt(pepeDss)
fetScore   = scoreIt(fetDss)
wldScore   = scoreIt(wldDss)

// === COMPOSITE DSS BREATHING SCORE ===
rawScore = btcScore + ethScore + xrpScore +
     bnbScore + solScore + dogeScore +
     adaScore + trxScore + avaxScore +
     shibScore + tonScore + linkScore +
     suiScore + dotScore + nearScore +
     uniScore + aptScore + polScore +
     arbScore + opScore +
     icpScore + hbarScore + filScore +
     atomScore + imxScore + injScore +
     stxScore + ftmScore + grtScore +
     thetaScore + algoScore + ldoScore +
     aaveScore + mkrScore + snxScore +
     vetScore + xlmScore + pepeScore +
     fetScore + wldScore

normalizedScore = rawScore * 20.0 / TOTAL_COINS
dssBreathScore = ta.ema(normalizedScore, scoreEmaLen)

// === ZONE COUNTS ===
buyCount = 0
buyCount += btcDss < osLevel ? 1 : 0
buyCount += ethDss < osLevel ? 1 : 0
buyCount += xrpDss < osLevel ? 1 : 0
buyCount += bnbDss < osLevel ? 1 : 0
buyCount += solDss < osLevel ? 1 : 0
buyCount += dogeDss < osLevel ? 1 : 0
buyCount += adaDss < osLevel ? 1 : 0
buyCount += trxDss < osLevel ? 1 : 0
buyCount += avaxDss < osLevel ? 1 : 0
buyCount += shibDss < osLevel ? 1 : 0
buyCount += tonDss < osLevel ? 1 : 0
buyCount += linkDss < osLevel ? 1 : 0
buyCount += suiDss < osLevel ? 1 : 0
buyCount += dotDss < osLevel ? 1 : 0
buyCount += nearDss < osLevel ? 1 : 0
buyCount += uniDss < osLevel ? 1 : 0
buyCount += aptDss < osLevel ? 1 : 0
buyCount += polDss < osLevel ? 1 : 0
buyCount += arbDss < osLevel ? 1 : 0
buyCount += opDss < osLevel ? 1 : 0
buyCount += icpDss < osLevel ? 1 : 0
buyCount += hbarDss < osLevel ? 1 : 0
buyCount += filDss < osLevel ? 1 : 0
buyCount += atomDss < osLevel ? 1 : 0
buyCount += imxDss < osLevel ? 1 : 0
buyCount += injDss < osLevel ? 1 : 0
buyCount += stxDss < osLevel ? 1 : 0
buyCount += ftmDss < osLevel ? 1 : 0
buyCount += grtDss < osLevel ? 1 : 0
buyCount += thetaDss < osLevel ? 1 : 0
buyCount += algoDss < osLevel ? 1 : 0
buyCount += ldoDss < osLevel ? 1 : 0
buyCount += aaveDss < osLevel ? 1 : 0
buyCount += mkrDss < osLevel ? 1 : 0
buyCount += snxDss < osLevel ? 1 : 0
buyCount += vetDss < osLevel ? 1 : 0
buyCount += xlmDss < osLevel ? 1 : 0
buyCount += pepeDss < osLevel ? 1 : 0
buyCount += fetDss < osLevel ? 1 : 0
buyCount += wldDss < osLevel ? 1 : 0

sellCount = 0
sellCount += btcDss > obLevel ? 1 : 0
sellCount += ethDss > obLevel ? 1 : 0
sellCount += xrpDss > obLevel ? 1 : 0
sellCount += bnbDss > obLevel ? 1 : 0
sellCount += solDss > obLevel ? 1 : 0
sellCount += dogeDss > obLevel ? 1 : 0
sellCount += adaDss > obLevel ? 1 : 0
sellCount += trxDss > obLevel ? 1 : 0
sellCount += avaxDss > obLevel ? 1 : 0
sellCount += shibDss > obLevel ? 1 : 0
sellCount += tonDss > obLevel ? 1 : 0
sellCount += linkDss > obLevel ? 1 : 0
sellCount += suiDss > obLevel ? 1 : 0
sellCount += dotDss > obLevel ? 1 : 0
sellCount += nearDss > obLevel ? 1 : 0
sellCount += uniDss > obLevel ? 1 : 0
sellCount += aptDss > obLevel ? 1 : 0
sellCount += polDss > obLevel ? 1 : 0
sellCount += arbDss > obLevel ? 1 : 0
sellCount += opDss > obLevel ? 1 : 0
sellCount += icpDss > obLevel ? 1 : 0
sellCount += hbarDss > obLevel ? 1 : 0
sellCount += filDss > obLevel ? 1 : 0
sellCount += atomDss > obLevel ? 1 : 0
sellCount += imxDss > obLevel ? 1 : 0
sellCount += injDss > obLevel ? 1 : 0
sellCount += stxDss > obLevel ? 1 : 0
sellCount += ftmDss > obLevel ? 1 : 0
sellCount += grtDss > obLevel ? 1 : 0
sellCount += thetaDss > obLevel ? 1 : 0
sellCount += algoDss > obLevel ? 1 : 0
sellCount += ldoDss > obLevel ? 1 : 0
sellCount += aaveDss > obLevel ? 1 : 0
sellCount += mkrDss > obLevel ? 1 : 0
sellCount += snxDss > obLevel ? 1 : 0
sellCount += vetDss > obLevel ? 1 : 0
sellCount += xlmDss > obLevel ? 1 : 0
sellCount += pepeDss > obLevel ? 1 : 0
sellCount += fetDss > obLevel ? 1 : 0
sellCount += wldDss > obLevel ? 1 : 0

// === PHASE CLASSIFICATION ===
isBuyPhase  = dssBreathScore >= 5
isSellPhase = dssBreathScore <= -5
isNeutral   = not isBuyPhase and not isSellPhase

// === PHASE AGE ===
inhaleStart = isBuyPhase and not isBuyPhase[1]
exhaleStart = isSellPhase and not isSellPhase[1]
barsPerDay = 86400 / timeframe.in_seconds()
barsInInhale = ta.barssince(inhaleStart)
barsInExhale = ta.barssince(exhaleStart)
phaseAgeDays = isBuyPhase ?
     (na(barsInInhale) ? 0.0 :
     barsInInhale / barsPerDay) :
     isSellPhase ?
     (na(barsInExhale) ? 0.0 :
     barsInExhale / barsPerDay) : 0.0

// === SHORT SIGNAL DETECTION ===
var bool wasGreen = false
var bool shortArmed = false
var int lastShortBar = 0

if dssBreathScore > 0
    wasGreen := true

if dssBreathScore < shortThreshold and wasGreen
    shortArmed := true

shortFired = false
if shortArmed and dssBreathScore > dssBreathScore[1]
     and dssBreathScore[1] <= dssBreathScore[2]
     and dssBreathScore < 0
     and (bar_index - lastShortBar) >= shortCooldown
    shortFired := true
    shortArmed := false
    lastShortBar := bar_index
    wasGreen := false

if shortArmed and dssBreathScore > 0
    shortArmed := false
    wasGreen := false

// === DISPLAY ===
scoreColor = dssBreathScore > 5 ?
     color.new(#00E676, 0) :
     dssBreathScore > 0 ?
     color.new(#81C784, 0) :
     dssBreathScore < -5 ?
     color.new(#FF1744, 0) :
     dssBreathScore < 0 ?
     color.new(#EF9A9A, 0) :
     color.new(#FFD600, 0)

plot(dssBreathScore, "DSS Breathing Score",
     color=scoreColor, linewidth=3,
     style=plot.style_area)

// Reference lines
hline(10, "Strong Buy",
     color=color.new(#00E676, 60),
     linestyle=hline.style_dotted)
hline(5, "Buy Zone",
     color=color.new(#00E676, 70),
     linestyle=hline.style_dashed)
hline(0, "Neutral",
     color=color.new(#666666, 50),
     linestyle=hline.style_dotted)
hline(-5, "Sell Zone",
     color=color.new(#FF1744, 70),
     linestyle=hline.style_dashed)
hline(-10, "Strong Sell",
     color=color.new(#FF1744, 60),
     linestyle=hline.style_dotted)

// Phase background
bgcolor(isBuyPhase ?
     color.new(#00E676, 92) :
     isSellPhase ?
     color.new(#FF1744, 92) : na,
     title="Phase BG")

// Short signal arrow
plotshape(shortFired, title="SHORT",
     location=location.top,
     style=shape.triangledown,
     size=size.normal,
     color=color.new(#FF6D00, 0),
     text="SHORT")

// === ALERTS ===
alertcondition(shortFired,
     title="DSS Breathing Short Signal",
     message="DSS Breathing: Deep red rollover — SHORT")

if shortFired
    alert('{"signal":"SHORT","type":"dss",' +
         '"score":' +
         str.tostring(dssBreathScore, "#.##") +
         ',"buyZone":' + str.tostring(buyCount) +
         ',"sellZone":' + str.tostring(sellCount) +
         ',"raw":' +
         str.tostring(normalizedScore, "#.##") +
         '}', alert.freq_once_per_bar)

// === INFO TABLE ===
var table t = table.new(position.top_right, 2, 9,
     bgcolor=color.new(#1E1E1E, 10),
     border_color=color.gray, border_width=1)

if barstate.islast
    // Title
    table.cell(t, 0, 0, "DSS Breathing",
         text_color=color.new(#00BCD4, 0),
         text_size=size.small,
         bgcolor=color.new(#333333, 0))
    phase = isBuyPhase ? "INHALE" :
         isSellPhase ? "EXHALE" : "BETWEEN"
    phCol = isBuyPhase ? color.green :
         isSellPhase ? color.red : color.yellow
    table.cell(t, 1, 0, phase,
         text_color=phCol,
         text_size=size.small,
         bgcolor=color.new(#333333, 0))

    // Score
    table.cell(t, 0, 1, "Score",
         text_color=color.gray,
         text_size=size.tiny)
    table.cell(t, 1, 1,
         str.tostring(dssBreathScore, "#.#"),
         text_color=phCol,
         text_size=size.tiny)

    // Buy zone (oversold)
    table.cell(t, 0, 2, "Oversold",
         text_color=color.gray,
         text_size=size.tiny)
    table.cell(t, 1, 2,
         str.tostring(buyCount) + "/40",
         text_color=color.green,
         text_size=size.tiny)

    // Sell zone (overbought)
    table.cell(t, 0, 3, "Overbought",
         text_color=color.gray,
         text_size=size.tiny)
    table.cell(t, 1, 3,
         str.tostring(sellCount) + "/40",
         text_color=color.red,
         text_size=size.tiny)

    // Longs
    table.cell(t, 0, 4, "Longs",
         text_color=color.gray,
         text_size=size.tiny)
    longAdv = isBuyPhase ? "GO" :
         isNeutral ? "WAIT" : "NO"
    longCol = isBuyPhase ? color.green :
         isNeutral ? color.yellow : color.red
    table.cell(t, 1, 4, longAdv,
         text_color=longCol,
         text_size=size.tiny)

    // Shorts
    table.cell(t, 0, 5, "Shorts",
         text_color=color.gray,
         text_size=size.tiny)
    shortAdv = isSellPhase ? "GO" :
         isNeutral ? "WAIT" : "NO"
    shortCol = isSellPhase ? color.green :
         isNeutral ? color.yellow : color.red
    table.cell(t, 1, 5, shortAdv,
         text_color=shortCol,
         text_size=size.tiny)

    // Phase Age
    table.cell(t, 0, 6, "Phase Age",
         text_color=color.gray,
         text_size=size.tiny)
    phAgeStr = (isBuyPhase or isSellPhase) ?
         str.tostring(phaseAgeDays, "#") + "d" : "—"
    table.cell(t, 1, 6, phAgeStr,
         text_color=(isBuyPhase or isSellPhase) ?
         color.green : color.gray,
         text_size=size.tiny)

    // Short armed
    table.cell(t, 0, 7, "Short",
         text_color=color.gray,
         text_size=size.tiny)
    shortStatus = shortArmed ? "ARMED" : "—"
    shortStatCol = shortArmed ?
         color.new(#FF6D00, 0) : color.gray
    table.cell(t, 1, 7, shortStatus,
         text_color=shortStatCol,
         text_size=size.tiny)

    // Timeframe
    table.cell(t, 0, 8, "TF",
         text_color=color.gray,
         text_size=size.tiny)
    table.cell(t, 1, 8, scoreTf,
         text_color=color.white,
         text_size=size.tiny)
